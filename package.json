{
	"private": true,
	"scripts": {
		"dev": "astro dev",
		"lint:astro": "astro check",
		"lint:tsc": "tsc",
		"lint": "run-p lint:*",
		"format": "prettier -uw --cache --plugin-search-dir=. .",
		"build": "astro build",
		"preview": "astro preview"
	},
	"devDependencies": {
		"@astrojs/tailwind": "0.2.2",
		"@types/node": "17.0.36",
		"@types/tailwindcss": "3.0.10",
		"astro": "1.0.0-beta.63",
		"lint-staged": "13.0.3",
		"npm-run-all": "4.1.5",
		"prettier": "2.7.1",
		"prettier-plugin-astro": "0.1.1",
		"simple-git-hooks": "2.8.0",
		"typescript": "4.7.4"
	},
	"simple-git-hooks": {
		"pre-commit": "pnpm lint-staged"
	},
	"lint-staged": {
		"*": "prettier -uw --plugin-search-dir=."
	},
	"packageManager": "pnpm@7.4.1",
	"engines": {
		"node": ">=16",
		"pnpm": ">=7"
	}
}
